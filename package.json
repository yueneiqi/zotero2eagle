{
  "name": "zotero2eagle",
  "type": "module",
  "version": "0.0.1",
  "description": "Zotero to Eagle integration plugin",
  "config": {
    "addonName": "Zotero2Eagle",
    "addonID": "zotero2eagle@euclpts.com",
    "addonRef": "zotero2eagle",
    "addonInstance": "Zotero2Eagle",
    "prefsPrefix": "extensions.zotero.zotero2eagle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-github-name/zotero2eagle.git"
  },
  "author": "Your Name",
  "bugs": {
    "url": "https://github.com/your-github-name/zotero2eagle/issues"
  },
  "homepage": "https://github.com/your-github-name/zotero2eagle#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.0-beta.8"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.0",
    "eslint": "^9.36.0",
    "mocha": "^11.7.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "zotero-plugin-scaffold": "^0.8.0",
    "zotero-types": "^4.1.0-beta.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
